  "keyFeatures": [
    "Lead/Worker coordination with autonomous task delegation",
    "Docker-isolated agents with persistent identity and memory",
    "Compounding memory system with embeddings and session learning",
    "Slack, GitHub, and Email integrations for task creation",
    "Hook system for safety, context management, and persistence",
    "Service discovery and inter-agent communication",
    "Cron-based scheduled tasks and epic management",
    "Real-time dashboard for monitoring agents and tasks"
